# Optional - enables LLM-authored narratives. The demo works fully WITHOUT this (deterministic
# Jinja2 templates are the default). No real secrets are required anywhere.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-5

# Runtime (set by the platform; sensible defaults baked into the image)
# PORT=8080
# DATA_DIR=/app/data
